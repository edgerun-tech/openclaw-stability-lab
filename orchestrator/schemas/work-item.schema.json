{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "kind", "source", "number", "profile", "status", "createdAt"],
  "properties": {
    "id": {"type": "string"},
    "kind": {"enum": ["issue", "pr", "check"]},
    "source": {"type": "string"},
    "number": {"type": "integer"},
    "title": {"type": "string"},
    "profile": {"type": "string"},
    "status": {"enum": ["new", "queued", "assigned", "running", "done", "failed", "needs-info"]},
    "priority": {"type": "integer"},
    "labels": {"type": "array", "items": {"type": "string"}},
    "createdAt": {"type": "string"},
    "updatedAt": {"type": "string"}
  }
}
