{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["workItemId", "runner", "repo", "commit", "profile", "verdict", "startedAt", "endedAt"],
  "properties": {
    "workItemId": {"type": "string"},
    "runner": {"type": "string"},
    "repo": {"type": "string"},
    "commit": {"type": "string"},
    "profile": {"type": "string"},
    "verdict": {"enum": ["reproducible", "not-reproducible", "needs-more-info", "duplicate/superseded"]},
    "startedAt": {"type": "string"},
    "endedAt": {"type": "string"},
    "artifacts": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  }
}
